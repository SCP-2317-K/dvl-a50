import json
import socket
import threading
import tkinter as tk
from tkinter import ttk
import sys

# DVL A50 預設網路設定
DVL_IP = "192.168.2.95"
DVL_PORT = 16171

# ==========================================
# 核心應用程式類別 (處理資料與介面更新)
# ==========================================
class DVLMonitorApp:
    def __init__(self, root, connected_client):
        self.root = root
        # 接收已經連線成功的 Socket！
        self.client = connected_client 
        
        self.root.title("Water Linked DVL A50 監測面板")
        self.root.geometry("400x420")
        self.root.configure(padx=20, pady=20)

        self.is_connected = True
        self.data_valid = False
        self.vx, self.vy, self.vz = 0.0, 0.0, 0.0
        self.raw_x, self.raw_y, self.raw_z = 0.0, 0.0, 0.0
        self.offset_x, self.offset_y, self.offset_z = 0.0, 0.0, 0.0
        self.last_time = None

        self.create_widgets()

        self.running = True
        self.net_thread = threading.Thread(target=self.tcp_loop, daemon=True)
        self.net_thread.start()

        self.update_ui()

    def create_widgets(self):
        self.lbl_status = ttk.Label(self.root, text="連線狀態: 🟢 已連線", font=("Arial", 12, "bold"), foreground="green")
        self.lbl_status.grid(row=0, column=0, columnspan=2, pady=(0, 15), sticky="w")

        frame_vel = ttk.LabelFrame(self.root, text=" 速度 (Velocity - m/s) ", padding=10)
        frame_vel.grid(row=1, column=0, columnspan=2, sticky="ew", pady=5)
        self.lbl_vx = ttk.Label(frame_vel, text="Vx: 0.000", font=("Arial", 11))
        self.lbl_vx.grid(row=0, column=0, pady=2)
        self.lbl_vy = ttk.Label(frame_vel, text="Vy: 0.000", font=("Arial", 11))
        self.lbl_vy.grid(row=1, column=0, pady=2)
        self.lbl_vz = ttk.Label(frame_vel, text="Vz: 0.000", font=("Arial", 11))
        self.lbl_vz.grid(row=2, column=0, pady=2)

        frame_pos = ttk.LabelFrame(self.root, text=" 位置 (Position - m) ", padding=10)
        frame_pos.grid(row=2, column=0, columnspan=2, sticky="ew", pady=15)
        self.lbl_px = ttk.Label(frame_pos, text="X: 0.000", font=("Arial", 11, "bold"), foreground="blue")
        self.lbl_px.grid(row=0, column=0, pady=2)
        self.lbl_py = ttk.Label(frame_pos, text="Y: 0.000", font=("Arial", 11, "bold"), foreground="blue")
        self.lbl_py.grid(row=1, column=0, pady=2)
        self.lbl_pz = ttk.Label(frame_pos, text="Z: 0.000", font=("Arial", 11, "bold"), foreground="blue")
        self.lbl_pz.grid(row=2, column=0, pady=2)

        self.btn_reset = ttk.Button(self.root, text="位置歸零 (Reset)", command=self.reset_position)
        self.btn_reset.grid(row=3, column=0, columnspan=2, pady=10, ipadx=20, ipady=5)

    def reset_position(self):
        self.offset_x, self.offset_y, self.offset_z = self.raw_x, self.raw_y, self.raw_z
        print("位置已歸零！")

    def process_packet(self, pkt):
        pkt_type = pkt.get("type")
        
        def safe_float(val, default=0.0):
            try:
                return float(val) if val is not None else default
            except (ValueError, TypeError):
                return default

        if pkt_type == "velocity":
            self.data_valid = pkt.get("velocity_valid", pkt.get("valid", False))
            self.vx, self.vy, self.vz = safe_float(pkt.get("vx")), safe_float(pkt.get("vy")), safe_float(pkt.get("vz"))
            
            time_raw = pkt.get("time_of_validity")
            time_ms = safe_float(time_raw) / 1000.0 if time_raw is not None else safe_float(pkt.get("time"))
                
            if self.last_time is not None and self.data_valid:
                dt = (time_ms - self.last_time) / 1000.0
                if 0 < dt < 1.0:
                    self.raw_x += self.vx * dt
                    self.raw_y += self.vy * dt
                    self.raw_z += self.vz * dt
            self.last_time = time_ms
            
        elif pkt_type == "position_local":
            self.raw_x, self.raw_y, self.raw_z = safe_float(pkt.get("x"), self.raw_x), safe_float(pkt.get("y"), self.raw_y), safe_float(pkt.get("z"), self.raw_z)

    def tcp_loop(self):
        buffer = ""
        try:
            while self.running:
                raw_data = self.client.recv(2048)
                if not raw_data:
                    self.is_connected = False
                    break
                
                buffer += raw_data.decode("utf-8", errors="ignore")
                while "\n" in buffer:
                    line, buffer = buffer.split("\n", 1)
                    line = line.strip()
                    if line:
                        try:
                            self.process_packet(json.loads(line))
                        except (json.JSONDecodeError, Exception):
                            pass
                            
        except Exception as e:
            print(f"網路接收錯誤: {e}")
            self.is_connected = False
        finally:
            self.client.close()

    def update_ui(self):
        if self.is_connected:
            self.lbl_status.config(text="連線狀態: 🟢 已連線 (資料有效)" if self.data_valid else "連線狀態: 🟠 尋找底部中...", foreground="green" if self.data_valid else "orange")
        else:
            self.lbl_status.config(text="連線狀態: 🔴 已斷線", foreground="red")

        self.lbl_vx.config(text=f"Vx: {self.vx:8.4f}")
        self.lbl_vy.config(text=f"Vy: {self.vy:8.4f}")
        self.lbl_vz.config(text=f"Vz: {self.vz:8.4f}")

        self.lbl_px.config(text=f"X: {self.raw_x - self.offset_x:8.4f}")
        self.lbl_py.config(text=f"Y: {self.raw_y - self.offset_y:8.4f}")
        self.lbl_pz.config(text=f"Z: {self.raw_z - self.offset_z:8.4f}")

        self.root.after(100, self.update_ui)

    def on_closing(self):
        self.running = False
        self.root.destroy()

# ==========================================
# 程式進入點 (先連線，再開視窗)
# ==========================================
if __name__ == "__main__":
    print("-" * 50)
    print(f"🔍 檢查環境：目前使用的 Python 為:\n   {sys.executable}")
    print("-" * 50)
    print(f"🔄 正在嘗試連線至 DVL ({DVL_IP}:{DVL_PORT})...")
    
    try:
        # 完全模仿您第一版成功連線的寫法，在主執行緒中連線
        init_client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        init_client.settimeout(5.0)
        init_client.connect((DVL_IP, DVL_PORT))
        init_client.settimeout(None)
        
        print("✅ 連線成功！準備啟動監控面板...")
        
        # 只有在連線成功後，才會開啟 Tkinter 視窗
        root = tk.Tk()
        app = DVLMonitorApp(root, init_client)
        root.protocol("WM_DELETE_WINDOW", app.on_closing)
